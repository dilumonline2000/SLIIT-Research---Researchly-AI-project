# ============================================
# Researchly AI Platform — Environment Template
# Copy to .env and fill in real values
# ============================================

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---------- API Gateway ----------
API_GATEWAY_PORT=3001
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:3001

# ---------- Python ML Services ----------
MODULE1_URL=http://localhost:8001
MODULE2_URL=http://localhost:8002
MODULE3_URL=http://localhost:8003
MODULE4_URL=http://localhost:8004

# ---------- External APIs (scrapers/data collection) ----------
IEEE_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
HF_TOKEN=

# ---------- ML Model Paths ----------
MODEL_CACHE_DIR=./models
SBERT_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
SCIBERT_MODEL_NAME=allenai/scibert_scivocab_uncased
SENTIMENT_MODEL_NAME=bert-base-uncased
SUMMARIZER_MODEL_NAME=facebook/bart-large-cnn

# ---------- Logging ----------
LOG_LEVEL=info
NODE_ENV=development
